APP_ENV=production

# Telegram Bot (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_USERNAME=your_bot_username

# Generate with: python3 -c "import secrets; print(secrets.token_hex(24))"
TELEGRAM_WEBHOOK_SECRET=your_random_secret_here

# Set AFTER first deploy — copy URL from Railway dashboard
# Railway also sets RAILWAY_PUBLIC_DOMAIN automatically, so this is optional
APP_BASE_URL=https://your-project.up.railway.app
