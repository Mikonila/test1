# Server
NODE_ENV=production
PORT=3000
APP_BASE_URL=https://your-free-domain.example

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
